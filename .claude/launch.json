{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 3001
    },
    {
      "name": "backend",
      "runtimeExecutable": "backend/venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["main:app", "--port", "8001", "--app-dir", "backend"],
      "port": 8001
    },
    {
      "name": "frontend-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "preview"],
      "port": 3001
    }
  ]
}
